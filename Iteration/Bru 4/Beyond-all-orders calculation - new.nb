      SubscriptBox["sol", 
       RowBox[{"1", ",", "1"}]], "/.", "\[Mu]val"}], "/.", "parval"}], "/.", 
    "C11eval"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"negativetab", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "*", "subsub", "*", "x"}]], "->", "0"}], ",", 
     RowBox[{"{", 
      RowBox[{"subsub", ",", 
       RowBox[{"-", "nmax"}], ",", 
       RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"positivetab", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "*", "subsub", "*", "x"}]], "->", "0"}], ",", 
