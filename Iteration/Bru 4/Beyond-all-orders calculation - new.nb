Cell[BoxData[{
 RowBox[{
  RowBox[{"kinetics", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"b", "+", "1"}], ")"}], "*", "u"}], "+", 
      RowBox[{
       SuperscriptBox["u", "2"], "*", "v"}], "+", 
      RowBox[{"\[Alpha]", "*", 
       RowBox[{"(", 
        RowBox[{"w", "-", "u"}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{"b", "*", "u"}], "-", 
      RowBox[{
       SuperscriptBox["u", "2"], "*", "v"}], "+", 
      RowBox[{"\[Beta]", "*", 
       RowBox[{"(", 
        RowBox[{"z", "-", "v"}], ")"}]}]}], ",", 
     RowBox[{"a", "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"b", "+", "1"}], ")"}], "*", "w"}], "+", 
      RowBox[{
       SuperscriptBox["w", "2"], "*", "z"}], "+", 
      RowBox[{"\[Alpha]", "*", 
       RowBox[{"(", 
        RowBox[{"u", "-", "w"}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{"b", "*", "w"}], "-", 
      RowBox[{
       SuperscriptBox["w", "2"], "*", "z"}], "+", 
      RowBox[{"\[Beta]", "*", 
       RowBox[{"(", 
        RowBox[{"v", "-", "z"}], ")"}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"diffmatrix", "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SuperscriptBox["\[Delta]", "2"], "0", "0", "0"},
      {"0", "1", "0", "0"},
      {"0", "0", 
       SuperscriptBox["\[Delta]", "2"], "0"},
      {"0", "0", "0", "1"}
     }], "\[NoBreak]", ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq", "=", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{"kinetics", "==", "0"}], ",", "var"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"jacmat", "=", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{"kinetics", ",", 
      RowBox[{"{", "var", "}"}]}], "]"}], "/.", "eq"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kinetics", "=", 
   RowBox[{"kinetics", "/.", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"var", "[", 
        RowBox[{"[", "varnum", "]"}], "]"}], "->", 
       RowBox[{
        RowBox[{"var", "[", 
         RowBox[{"[", "varnum", "]"}], "]"}], "+", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"var", "[", 
           RowBox[{"[", "varnum", "]"}], "]"}], "/.", "eq"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"varnum", ",", "nvar"}], "}"}]}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.916232479613204*^9, {3.916504896738484*^9, 3.9165049122998133`*^9}, 
