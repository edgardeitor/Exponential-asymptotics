    RowBox[{"dummymat", ",", "dummyvec"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"toexpand", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        RowBox[{
        "var", "\[LeftDoubleBracket]", "varnum", "\[RightDoubleBracket]"}], 
        "order"], "\[Rule]", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["WNF", 
            RowBox[{"order", ",", "sub", ",", "varnum"}]], " ", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"\[ImaginaryI]", " ", "sub", " ", "x"}]]}], "/.", 
          RowBox[{
           SubscriptBox["WNF", 
            RowBox[{"order", ",", "sub", ",", "varnum"}]], "->", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"sub", "<", "0"}], ",", 
             RowBox[{
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"-", "1"}], ")"}], "order"], "*", 
               SuperscriptBox["\[ExponentialE]", 
                RowBox[{"2", "*", "sub", "*", "\[Xi]NF", "*", "\[Pi]"}]], "*", 
               RowBox[{"Conjugate", "[", 
                SubscriptBox["WNF", 
                 RowBox[{"order", ",", 
                  RowBox[{"-", "sub"}], ",", "varnum"}]], "]"}]}], "/.", 
              "\[Xi]val"}], ",", 
             SubscriptBox["WNF", 
              RowBox[{"order", ",", "sub", ",", "varnum"}]]}], "]"}]}]}], ",", 
