Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Psi]NF", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     SubscriptBox["vNF", "varnum"], ",", 
     RowBox[{"{", 
      RowBox[{"varnum", ",", "nvar"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Psi]NF", "[", 
    RowBox[{"[", "criticalrow", "]"}], "]"}], "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Psi]sol", "=", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Dot", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"jacobianmat", "[", 
           RowBox[{"[", 
            RowBox[{"submatrixrows", ",", "submatrixcols"}], "]"}], "]"}], 
          "]"}], ",", 
         RowBox[{"\[Psi]NF", "[", 
          RowBox[{"[", "submatrixrows", "]"}], "]"}]}], "]"}], "==", 
       RowBox[{"-", 
        RowBox[{"Transpose", "[", 
         RowBox[{"jacobianmat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"{", "criticalrow", "}"}], ",", "submatrixcols"}], "]"}], 
          "]"}], "]"}]}]}], ",", 
      RowBox[{"\[Psi]NF", "[", 
       RowBox[{"[", "submatrixrows", "]"}], "]"}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
