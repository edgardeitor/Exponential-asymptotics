     SubscriptBox["param", "0"], ",", 
     SubscriptBox["param", "1"], ",", 
     SubscriptBox["param", "2"]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"fitpar", "=", 
  RowBox[{"FindFit", "[", 
   RowBox[{
    RowBox[{"Table", "[", 
