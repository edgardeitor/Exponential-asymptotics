Cell[BoxData[{
 RowBox[{
  RowBox[{"c20funabs", "=", 
   RowBox[{
    SubscriptBox["param", "0"], "+", 
    FractionBox[
     SubscriptBox["param", "1"], "n"], "+", 
    FractionBox[
     SubscriptBox["param", "2"], 
     SuperscriptBox["n", "2"]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"parameters", "=", 
   RowBox[{"{", 
