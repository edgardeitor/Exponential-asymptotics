ed21a0f12443"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"load", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"FileExistsQ", "[", "\"\<savedSession.mx\>\"", "]"}], " ", "&&", 
    " ", 
    RowBox[{"load", "==", "1"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"<<", "savedSession.mx"}], "\[IndentingNewLine]", ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solvcond", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"ampeval", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"solvcond", ",", "0"}], "]"}], ";"}]}], "\[IndentingNewLine]", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"order", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"solvcond", "==", 
       RowBox[{"{", "}"}]}], ",", "2", ",", 
      RowBox[{
       RowBox[{"Length", "[", "solvcond", "]"}], "+", "1"}]}], "]"}]}], ",", 
   RowBox[{"order", "<=", "nmax"}], ",", 
   RowBox[{"order", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"save", "=", "0"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<order=\>\"", "<>", 
      RowBox[{"ToString", "[", "order", "]"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"derivative", "=", 
     RowBox[{"D", "[", 
      RowBox[{"derivative", ",", "\[Epsilon]NF"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"toexpand", "=", 
     RowBox[{"toexpand", "/.", "ampeval"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"equation", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        FractionBox["1", 
         RowBox[{"order", "!"}]], "*", "derivative"}], "/.", 
       RowBox[{"\[Epsilon]NF", "->", "0"}]}], "/.", "toexpand"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"equation", "=", 
     RowBox[{
      RowBox[{"Expand", "[", "equation", "]"}], "/.", "negativetab"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"OddQ", "[", "order", "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"sub", "=", "1"}], ";", "\[IndentingNewLine]", 
       RowBox[{"auxeq", "=", 
        RowBox[{
         FractionBox["1", 
          RowBox[{"2", "\[Pi]"}]], 
         RowBox[{
          SubsuperscriptBox["\[Integral]", "0", 
           RowBox[{"2", "\[Pi]"}]], 
          RowBox[{"equation", "*", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{
             RowBox[{"-", "\[ImaginaryI]"}], "*", "sub", "*", "x"}]], 
           RowBox[{"\[DifferentialD]", "x"}]}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"auxeq", "=", 
        RowBox[{
         RowBox[{"-", "auxeq"}], "/.", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             SubscriptBox["WNF", 
              RowBox[{"order", ",", "aux", ",", "varnum"}]], "->", "0"}], ",", 
            RowBox[{"{", 
             RowBox[{"aux", ",", 
              RowBox[{"-", "order"}], ",", "order", ",", "2"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"varnum", ",", "nvar"}], "}"}]}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"order", ">=", "3"}], ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"order", "-", "2"}], ">=", "sub"}], " ", "&&", " ", 
            RowBox[{"OddQ", "[", "order", "]"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"auxeq", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"auxeq", "-", 
                RowBox[{"2", "*", "\[ImaginaryI]", "*", "sub", "*", 
                 FractionBox[
                  RowBox[{"order", "-", "2", "-", 
