  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"toexpand", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        RowBox[{
        "var", "\[LeftDoubleBracket]", "varnum", "\[RightDoubleBracket]"}], 
        "order"], "\[Rule]", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["WNF", 
            RowBox[{"order", ",", "sub", ",", "varnum"}]], " ", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"\[ImaginaryI]", " ", "sub", " ", "x"}]]}], "/.", 
